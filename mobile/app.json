{
  "expo": {
    "name": "TallerOS",
    "slug": "talleros",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#16191d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.talleros.app"
    },
    "android": {
      "package": "com.talleros.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5B700"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "apiUrl": "https://app-talleros.onrender.com",
      "eas": {
        "projectId": "efeefa2e-b6e4-497f-8c30-f96402e911c3"
      }
    },
    "icon": "./assets/icon.png",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permite compartir tu ubicación cuando solicitas auxilio vial."
        }
      ]
    ]
  }
}
# ===== Servidor =====
PORT=4000
# Origen permitido del frontend (web admin / apps). Usa * solo en desarrollo.
CORS_ORIGIN=*

# ===== Base de datos PostgreSQL =====
# Opción 1: una sola URL (recomendado en servicios como Render/Railway/Neon)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/talleros
# Opción 2: variables sueltas (si no usas DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=talleros

# ===== Seguridad =====
# Cambia esto por una cadena larga y secreta en producción.
JWT_SECRET=cambia-esta-clave-por-una-larga-y-secreta
JWT_EXPIRES=7d

# ===== Correo (recuperación de contraseña, actas) =====
# Deja vacío para modo demo (el código se imprime en consola).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=TallerOS <no-reply@talleros.com>

# ===== WhatsApp Business (Twilio o Meta) =====
# Deja vacío para modo demo (el mensaje se imprime en consola).
WHATSAPP_PROVIDER=             # twilio | meta | (vacío = demo)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
META_TOKEN=
META_PHONE_ID=

# ===== Almacenamiento de archivos =====
# 'local' guarda en /uploads. En producción usa S3 / Cloudflare R2.
STORAGE=local
UPLOAD_DIR=uploads
